<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.institute.backgroundsyncd</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>INSTALL_DIR_PLACEHOLDER/wrapper.sh</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <false/>

    <!-- Background priority — yields to foreground apps -->
    <key>Nice</key>
    <integer>10</integer>

    <!-- Background process type reduces Activity Monitor prominence -->
    <key>ProcessType</key>
    <string>Background</string>

    <key>StandardOutPath</key>
    <string>INSTALL_DIR_PLACEHOLDER/sync.log</string>

    <key>StandardErrorPath</key>
    <string>INSTALL_DIR_PLACEHOLDER/sync.log</string>

</dict>
</plist>
